#include <Wire.h>
#include <LiquidCrystal.h>
#include <DHT.h>
#include <MAX30100_PulseOximeter.h>
#include <SoftwareSerial.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BMP280.h>

#define DHTPIN 2
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);

LiquidCrystal lcd(12, 11, 5, 4, 3, 2);

MAX30100_PulseOximeter pox(SDA, SCL);

SoftwareSerial mySerial(10, 9); // RX, TX for GSM module
#define BMP_SCK 13
#define BMP_MISO 12
#define BMP_MOSI 11
#define BMP_CS 10

Adafruit_BMP280 bmp; // I2C

void setup() {
  Serial.begin(9600);
  mySerial.begin(9600);
  dht.begin();
  lcd.begin(16, 2);
  pox.begin();
  if (!bmp.begin()) {
    Serial.println(F("Could not find a valid BMP280 sensor, check wiring!"));
    while (1);
  }
}

void loop() {
  float temperature = dht.readTemperature();
  float humidity = dht.readHumidity();
  float pressure = bmp.readPressure() / 100.0F; // hPa

  lcd.setCursor(0, 0);
  lcd.print("Temp: ");
  lcd.print(temperature);
  lcd.print("C");

  lcd.setCursor(0, 1);
  lcd.print("Humidity: ");
  lcd.print(humidity);
  lcd.print("%");

  lcd.setCursor(9, 0);
  lcd.print("Pressure: ");
  lcd.print(pressure);
  lcd.print("hPa");

  if (temperature > 37 || humidity > 60 || pressure > 1015) {
    lcd.setCursor(0, 1);
    lcd.print("ALERT!");
    sendSMS("Alert: Temp/Humidity/Pressure exceeded limits!");
  }

  if (pox.available()) {
    int heartRate = pox.getHeartRate();
    lcd.setCursor(0, 1);
    lcd.print("Heart Rate: ");
    lcd.print(heartRate);
    lcd.print("bpm");

    if (heartRate > 110) {
      lcd.setCursor(0, 1);
      lcd.print("ALERT!");
      sendSMS("Alert: Heart Rate exceeded limit!");
    }
  }

  delay(1000);
}

void sendSMS(String message) {
  mySerial.println("AT+CMGF=1"); // Set SMS mode to text
  delay(100);
  mySerial.println("AT+CMGS=\"+1234567890\""); // Replace with your mobile number
  delay(100);
  mySerial.println(message);
  delay(100);
  mySerial.println((char)26); // End AT command with Ctrl+Z
  delay(100);
  mySerial.println();
}
